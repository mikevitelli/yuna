{
  "name": "yuna-bot",
  "version": "0.1.0",
  "description": "Self-hosted AI-powered multi-device orchestrator over Telegram. Claude picks the right device and runs the command — devices are just hands.",
  "type": "module",
  "bin": { "yuna": "./bin/yuna.js" },
  "files": [
    "bin/",
    "dist/",
    "server/src/",
    "server/package.json",
    "server/package-lock.json",
    "server/tsconfig.json",
    "server/next.config.ts",
    "server/next-env.d.ts",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup && cd server && npm run build",
    "build:cli": "tsup",
    "build:server": "cd server && npm run build",
    "dev": "cd server && npm run dev",
    "typecheck": "tsc --noEmit && cd server && npx tsc --noEmit",
    "prepublishOnly": "npm run build:cli"
  },
  "keywords": [
    "telegram",
    "bot",
    "claude",
    "anthropic",
    "ai-agent",
    "orchestrator",
    "multi-device",
    "self-hosted",
    "cli",
    "vercel",
    "upstash",
    "redis-streams",
    "tool-use"
  ],
  "author": "mikevitelli",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mikevitelli/yuna.git"
  },
  "homepage": "https://github.com/mikevitelli/yuna#readme",
  "bugs": { "url": "https://github.com/mikevitelli/yuna/issues" },
  "dependencies": {
    "commander": "^13.0.0",
    "inquirer": "^12.0.0",
    "chalk": "^5.4.0",
    "ora": "^8.2.0",
    "open": "^10.1.0"
  },
  "devDependencies": {
    "typescript": "^5.8.3",
    "tsup": "^8.4.0",
    "@types/node": "^22.14.1"
  },
  "engines": { "node": ">=18" }
}
