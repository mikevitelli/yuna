# ─── Anthropic ────────────────────────────────────────────────────────────────
# Claude API key (from https://console.anthropic.com/settings/keys)
ANTHROPIC_API_KEY=sk-ant-...

# ─── Upstash Redis ────────────────────────────────────────────────────────────
# Redis REST URL (from https://console.upstash.com)
UPSTASH_REDIS_REST_URL=https://...upstash.io
# Redis REST token
UPSTASH_REDIS_REST_TOKEN=...

# ─── Telegram ─────────────────────────────────────────────────────────────────
# Bot token (from @BotFather)
TELEGRAM_BOT_TOKEN=123456:ABC-DEF...
# Your Telegram user ID (from @userinfobot) — locks bot to one user
TELEGRAM_OWNER_ID=123456789
# Webhook verification secret (auto-generated by `yuna init`)
TELEGRAM_WEBHOOK_SECRET=...

# ─── Auth ─────────────────────────────────────────────────────────────────────
# Master secret hash — SHA-256 of the MASTER_SECRET (auto-generated by `yuna init`)
# The plaintext MASTER_SECRET is never stored on the server
MASTER_SECRET_HASH=...

# ─── Branding ─────────────────────────────────────────────────────────────────
# Bot display name (shown on landing page and in Telegram)
BOT_NAME=Yuna
# Owner display name
OWNER_NAME=Your Name
